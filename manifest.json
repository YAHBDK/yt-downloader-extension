{
  "manifest_version": 3,
  "name": "YouTube Downloader",
  "version": "9.2",
  "description": "הורד סרטונים ישירות בלחיצה",
  "key": "",
  "permissions": ["downloads", "storage", "notifications"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:9797/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
