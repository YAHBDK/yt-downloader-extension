{
  "manifest_version": 3,
  "name": "YouTube Downloader",
  "version": "9.0",
  "description": "הורד סרטוני יוטיוב ישירות בלחיצה",
  "key": "",
  "permissions": ["downloads"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:9797/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
